---
// Footer — dark multi-column layout.
// Columns: Brand + contact | Quick Links | Useful Links | Newsletter
const quickLinks = [
  { label: "Home", href: "/" },
  { label: "About Us", href: "#about" },
  { label: "Services", href: "#services" },
  { label: "Projects", href: "#projects" },
  { label: "FAQ", href: "#faq" },
];

const usefulLinks = [
  { label: "Privacy Policy", href: "#" },
  { label: "Terms of Service", href: "#" },
  { label: "Support", href: "#contact" },
  { label: "Careers", href: "#" },
  { label: "Blog", href: "#" },
];

const year = new Date().getFullYear();
---

<footer class="bg-ink text-white">
  <div class="container-site py-16">
    <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-4">
      <!-- Brand + contact -->
      <div class="sm:col-span-2 lg:col-span-1">
        <!-- Logo -->
        <a href="/" class="inline-flex items-center gap-2.5">
          <span
            class="flex h-9 w-9 items-center justify-center rounded-xl bg-accent"
          >
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              aria-hidden="true"
            >
              <path
                d="M14.7 6.3a4.5 4.5 0 0 0-6.09 5.4L3 17.3V21h3.7l5.6-5.6a4.5 4.5 0 0 0 5.4-6.1l-2.9 2.9-2.5-.5-.5-2.5 2.9-2.9Z"
                stroke="currentColor"
                stroke-width="1.7"
                stroke-linejoin="round"
              />
            </svg>
          </span>
          <span class="text-xl font-extrabold tracking-tight">PLUMBER.</span>
        </a>

        <p class="mt-4 text-sm leading-relaxed text-white/60">
          Quality workmanship and customer satisfaction — plumbing repairs,
          installations, and handyman services across New York, 24/7.
        </p>

        <!-- Contact details -->
        <ul class="mt-6 space-y-3 text-sm">
          <li>
            <a
              href="tel:+10011234567"
              class="flex items-center gap-3 text-white/60 transition hover:text-white"
            >
              <svg
                width="15"
                height="15"
                viewBox="0 0 24 24"
                fill="none"
                class="shrink-0"
                aria-hidden="true"
              >
                <path
                  d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.41a2 2 0 0 1 1.99-2.18h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 8.96a16 16 0 0 0 6.14 6.14l.96-1.96a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92Z"
                  stroke="currentColor"
                  stroke-width="1.7"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
              (001) 123 456 789
            </a>
          </li>
          <li>
            <a
              href="mailto:hello@plumber.com"
              class="flex items-center gap-3 text-white/60 transition hover:text-white"
            >
              <svg
                width="15"
                height="15"
                viewBox="0 0 24 24"
                fill="none"
                class="shrink-0"
                aria-hidden="true"
              >
                <rect
                  x="2"
                  y="4"
                  width="20"
                  height="16"
                  rx="2"
                  stroke="currentColor"
                  stroke-width="1.7"
                />
                <path
                  d="m2 7 10 7 10-7"
                  stroke="currentColor"
                  stroke-width="1.7"
                  stroke-linecap="round"
                />
              </svg>
              hello@plumber.com
            </a>
          </li>
          <li class="flex items-start gap-3 text-white/60">
            <svg
              width="15"
              height="15"
              viewBox="0 0 24 24"
              fill="none"
              class="mt-0.5 shrink-0"
              aria-hidden="true"
            >
              <path
                d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7Zm0 9.5a2.5 2.5 0 1 1 0-5 2.5 2.5 0 0 1 0 5Z"
                stroke="currentColor"
                stroke-width="1.7"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
            </svg>
            <span>
              123 Pipe Street, Brooklyn,<br />New York, NY 11201
            </span>
          </li>
        </ul>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-sm font-bold uppercase tracking-widest text-white">
          Quick Links
        </h3>
        <ul class="mt-5 space-y-3">
          {
            quickLinks.map(({ label, href }) => (
              <li>
                <a
                  href={href}
                  class="flex items-center gap-2 text-sm text-white/60 transition hover:text-white"
                >
                  <svg
                    width="12"
                    height="12"
                    viewBox="0 0 24 24"
                    fill="none"
                    aria-hidden="true"
                  >
                    <path
                      d="m9 18 6-6-6-6"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    />
                  </svg>
                  {label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Useful Links -->
      <div>
        <h3 class="text-sm font-bold uppercase tracking-widest text-white">
          Useful Links
        </h3>
        <ul class="mt-5 space-y-3">
          {
            usefulLinks.map(({ label, href }) => (
              <li>
                <a
                  href={href}
                  class="flex items-center gap-2 text-sm text-white/60 transition hover:text-white"
                >
                  <svg
                    width="12"
                    height="12"
                    viewBox="0 0 24 24"
                    fill="none"
                    aria-hidden="true"
                  >
                    <path
                      d="m9 18 6-6-6-6"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    />
                  </svg>
                  {label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Newsletter -->
      <div>
        <h3 class="text-sm font-bold uppercase tracking-widest text-white">
          Newsletter
        </h3>
        <p class="mt-5 text-sm leading-relaxed text-white/60">
          Subscribe for plumbing tips and seasonal maintenance reminders — no
          spam, unsubscribe any time.
        </p>
        <form class="mt-5 flex flex-col gap-3" novalidate>
          <label for="newsletter-email" class="sr-only">Email address for newsletter</label>
          <input
            id="newsletter-email"
            type="email"
            placeholder="Your email address"
            autocomplete="email"
            class="rounded-xl border border-white/10 bg-white/10 px-4 py-3 text-sm text-white placeholder:text-white/40 focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/50"
          />
          <button
            type="submit"
            class="rounded-full bg-accent py-3 text-sm font-semibold text-white transition hover:bg-accent-dark"
          >
            Subscribe Now
          </button>
        </form>
      </div>
    </div>

    <!-- Bottom bar -->
    <div
      class="mt-14 flex flex-col items-center justify-between gap-4 border-t border-white/10 pt-8 text-xs text-white/55 sm:flex-row"
    >
      <p>© {year} PLUMBER. All rights reserved.</p>
      <div class="flex gap-5">
        <a href="#" class="transition hover:text-white focus:outline-none focus:underline">Privacy</a>
        <a href="#" class="transition hover:text-white focus:outline-none focus:underline">Terms</a>
        <a href="#" class="transition hover:text-white focus:outline-none focus:underline">Sitemap</a>
      </div>
    </div>
  </div>
</footer>
