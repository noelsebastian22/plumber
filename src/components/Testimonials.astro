---
// Testimonials — "What Our Customer Says?"
// Mockup: centered heading, 3 review cards with avatar, stars, quote.
const testimonials = [
  {
    name: "Robert Johnson",
    role: "Homeowner, Brooklyn",
    avatar: "/images/unsplash/avatar-1.jpg",
    quote:
      "PLUMBER. fixed our burst pipe at 2 AM without any fuss. The technician was professional, clean, and had everything sorted within the hour. Pricing was exactly what they quoted — not a cent more.",
    stars: 5,
  },
  {
    name: "Maria Gonzalez",
    role: "Restaurant Owner, Manhattan",
    avatar: "/images/unsplash/avatar-2.jpg",
    quote:
      "We use PLUMBER. for all our commercial maintenance. Their team understands the urgency of keeping a kitchen running and they always show up on time. Five stars every single time.",
    stars: 5,
  },
  {
    name: "David Chen",
    role: "Property Manager, Queens",
    avatar: "/images/unsplash/avatar-3.jpg",
    quote:
      "Managing 30 units means plumbing emergencies are a fact of life. PLUMBER. is the only service I trust — fast, reliable, and their upfront pricing makes budgeting a breeze.",
    stars: 5,
  },
];
---

<section class="bg-surface py-16 md:py-24">
  <div class="container-site">
    <!-- Heading -->
    <div class="text-center">
      <p class="text-sm font-semibold uppercase tracking-widest text-accent-text">
        Testimonials
      </p>
      <h2 class="mt-3 text-3xl font-extrabold tracking-tight text-ink md:text-4xl">
        What our <span class="text-accent-text">customers</span> say
      </h2>
    </div>

    <!-- Cards -->
    <div class="mt-12 grid gap-6 md:grid-cols-3">
      {
        testimonials.map(({ name, role, avatar, quote, stars }) => (
          <article class="flex flex-col gap-5 rounded-[3px] bg-surface-alt p-7">
            <!-- Stars -->
            <div
              class="flex gap-1"
              role="img"
              aria-label={`${stars} out of 5 stars`}
            >
              {Array.from({ length: stars }).map(() => (
                <svg
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  class="text-star"
                  aria-hidden="true"
                >
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                </svg>
              ))}
            </div>
            <!-- Quote -->
            <p class="text-sm leading-relaxed text-muted">&ldquo;{quote}&rdquo;</p>
            <!-- Author -->
            <div class="mt-auto flex items-center gap-3 border-t border-line pt-5">
              <img
                src={avatar}
                alt={name}
                width="44"
                height="44"
                loading="lazy"
                class="h-11 w-11 rounded-full object-cover"
              />
              <div>
                <p class="text-sm font-bold text-ink">{name}</p>
                <p class="text-xs text-muted">{role}</p>
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
