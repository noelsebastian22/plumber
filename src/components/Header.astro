---
const links = [
  { label: "Home", href: "/", active: true },
  { label: "About Us", href: "#about" },
  { label: "Services", href: "#services" },
  { label: "Projects", href: "#projects" },
  { label: "Contact", href: "#contact" },
];
---

<header class="sticky top-0 z-50 border-b border-line bg-surface/95 backdrop-blur">
  <div class="container-site flex h-16 items-center justify-between gap-6">
    <a href="/" class="text-lg font-extrabold tracking-tight" aria-label="PLUMBER. — home">
      PLUMBER<span class="text-accent">.</span>
    </a>

    <nav class="hidden items-center gap-8 md:flex" aria-label="Main">
      {
        links.map(({ label, href, active }) => (
          <a
            href={href}
            class:list={[
              "text-sm font-medium transition-colors hover:text-accent",
              active ? "text-accent" : "text-ink",
            ]}
            aria-current={active ? "page" : undefined}
          >
            {label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-3">
      <a
        href="#contact"
        class="hidden rounded-full bg-ink px-5 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-accent md:inline-block"
      >
        Book Now
      </a>

      <button
        id="menu-toggle"
        type="button"
        class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-line md:hidden focus:outline-none focus:ring-2 focus:ring-accent"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Open menu"
      >
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <path d="M1 3.5h16M1 9h16M1 14.5h16" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
        </svg>
      </button>
    </div>
  </div>

  <nav id="mobile-menu" class="hidden border-t border-line bg-surface md:hidden" aria-label="Mobile">
    <div class="container-site flex flex-col gap-1 py-4">
      {
        links.map(({ label, href, active }) => (
          <a
            href={href}
            class:list={[
              "rounded-lg px-3 py-2.5 text-sm font-medium hover:bg-surface-alt",
              active ? "text-accent" : "text-ink",
            ]}
          >
            {label}
          </a>
        ))
      }
      <a
        href="#contact"
        class="mt-2 rounded-full bg-ink px-5 py-3 text-center text-sm font-semibold text-white"
      >
        Book Now
      </a>
    </div>
  </nav>
</header>

<script>
  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");

  toggle?.addEventListener("click", () => {
    const open = menu?.classList.toggle("hidden") === false;
    toggle.setAttribute("aria-expanded", String(open));
    toggle.setAttribute("aria-label", open ? "Close menu" : "Open menu");
  });

  menu?.addEventListener("click", (e) => {
    if ((e.target as HTMLElement).closest("a")) {
      menu.classList.add("hidden");
      toggle?.setAttribute("aria-expanded", "false");
    }
  });
</script>
