---
const links = [
  { label: "Home", href: "/", active: true },
  { label: "About Us", href: "#about" },
  { label: "Services", href: "#services" },
  { label: "Projects", href: "#projects" },
  { label: "Contact", href: "#contact" },
];
---

<header
  class="sticky top-0 z-50 border-b border-line bg-surface/95 backdrop-blur transition-shadow duration-300 ease-out-expo motion-reduce:transition-none"
  id="site-header"
>
  <div class="container-site flex h-16 items-center justify-between gap-6">
    <a href="/" class="text-lg font-extrabold tracking-tight" aria-label="PLUMBER. — home">
      PLUMBER<span class="text-accent">.</span>
    </a>

    <nav class="hidden items-center gap-8 md:flex" aria-label="Main">
      {
        links.map(({ label, href, active }) => (
          <a
            href={href}
            class:list={[
              "text-sm font-medium transition-colors hover:text-accent",
              active ? "text-accent" : "text-ink",
            ]}
            aria-current={active ? "page" : undefined}
          >
            {label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-3">
      <a
        href="#contact"
        class="hidden rounded-full bg-ink px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-accent active:scale-[0.97] md:inline-block"
      >
        Book Now
      </a>

      <!-- Hamburger / X toggle -->
      <button
        id="menu-toggle"
        type="button"
        class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-line md:hidden focus:outline-none"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Open menu"
      >
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <path class="bar bar-top" d="M1 3.5h16" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
          <path class="bar bar-mid" d="M1 9h16"   stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
          <path class="bar bar-bot" d="M1 14.5h16" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile dropdown — animated via JS (max-height + opacity) -->
  <nav
    id="mobile-menu"
    class="overflow-hidden border-t border-line bg-surface md:hidden"
    style="max-height:0;opacity:0;"
    aria-label="Mobile"
    aria-hidden="true"
  >
    <div class="container-site flex flex-col gap-1 py-4">
      {
        links.map(({ label, href, active }, i) => (
          <a
            href={href}
            class:list={[
              "nav-item rounded-lg px-3 py-2.5 text-sm font-medium hover:bg-surface-alt",
              active ? "text-accent" : "text-ink",
            ]}
            style={`--i:${i}`}
          >
            {label}
          </a>
        ))
      }
      <a
        href="#contact"
        class="nav-item mt-2 rounded-full bg-ink px-5 py-3 text-center text-sm font-semibold text-white transition active:scale-[0.97]"
        style={`--i:${links.length}`}
      >
        Book Now
      </a>
    </div>
  </nav>
</header>

<style>
  /* ── Hamburger bars: morph into × ──────────────────── */
  .bar {
    transform-box: fill-box;       /* transform relative to each path's own bbox */
    transform-origin: center;
    transition:
      transform 0.32s cubic-bezier(0.4, 0, 0.2, 1),
      opacity   0.22s ease;
  }

  /* top bar slides down to centre and tilts +45° */
  [aria-expanded="true"] .bar-top { transform: translateY(5.5px) rotate(45deg); }
  /* middle bar fades & shrinks away */
  [aria-expanded="true"] .bar-mid { opacity: 0; transform: scaleX(0); }
  /* bottom bar slides up to centre and tilts −45° */
  [aria-expanded="true"] .bar-bot { transform: translateY(-5.5px) rotate(-45deg); }

  /* ── Staggered nav items ────────────────────────────── */
  .nav-item {
    opacity: 0;
    transform: translateY(-8px);
  }

  /* when [data-open] is present on the menu, items animate in */
  #mobile-menu[data-open] .nav-item {
    opacity: 1;
    transform: translateY(0);
    transition:
      opacity   0.28s ease,
      transform 0.32s cubic-bezier(0.34, 1.56, 0.64, 1); /* gentle spring */
    transition-delay: calc(var(--i) * 48ms + 55ms);
  }

  /* ── Honour prefers-reduced-motion ─────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .bar,
    .nav-item {
      transition: none !important;
    }
  }
</style>

<script>
  const toggle = document.getElementById("menu-toggle") as HTMLButtonElement;
  const menu   = document.getElementById("mobile-menu") as HTMLElement;
  const header = document.getElementById("site-header");

  let isOpen  = false;
  const noAnim = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  const OPEN_T  = "max-height .38s cubic-bezier(.4,0,.2,1), opacity .28s ease";
  const CLOSE_T = "max-height .30s cubic-bezier(.4,0,.2,1), opacity .22s ease";

  /* ── open ──────────────────────────────────────────── */
  function openMenu() {
    isOpen = true;
    toggle.setAttribute("aria-expanded", "true");
    toggle.setAttribute("aria-label", "Close menu");
    menu.removeAttribute("aria-hidden");
    menu.dataset.open = "";                          // triggers CSS stagger

    if (noAnim) {
      menu.style.maxHeight = menu.scrollHeight + "px";
      menu.style.opacity   = "1";
      return;
    }
    menu.style.transition = OPEN_T;
    menu.style.maxHeight  = menu.scrollHeight + "px";
    menu.style.opacity    = "1";
  }

  /* ── close ─────────────────────────────────────────── */
  function closeMenu() {
    if (!isOpen) return;
    isOpen = false;
    toggle.setAttribute("aria-expanded", "false");
    toggle.setAttribute("aria-label", "Open menu");

    if (noAnim) {
      menu.style.maxHeight = "0";
      menu.style.opacity   = "0";
      menu.setAttribute("aria-hidden", "true");
      delete menu.dataset.open;
      return;
    }

    menu.style.transition = CLOSE_T;
    menu.style.maxHeight  = "0";
    menu.style.opacity    = "0";

    // Wait for max-height transition to finish before hiding items
    const onEnd = (e: TransitionEvent) => {
      if (e.propertyName !== "max-height") return;
      menu.removeEventListener("transitionend", onEnd);
      if (!isOpen) {
        menu.setAttribute("aria-hidden", "true");
        delete menu.dataset.open;
      }
    };
    menu.addEventListener("transitionend", onEnd);
  }

  /* ── wiring ─────────────────────────────────────────── */
  toggle.addEventListener("click", () => (isOpen ? closeMenu() : openMenu()));

  // Close when any link inside is tapped
  menu.addEventListener("click", (e) => {
    if ((e.target as HTMLElement).closest("a")) closeMenu();
  });

  // Close on Escape and return focus to the toggle
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && isOpen) { closeMenu(); toggle.focus(); }
  });

  // Auto-close if the viewport grows past the md breakpoint
  window.matchMedia("(min-width: 768px)").addEventListener("change", (e) => {
    if (e.matches && isOpen) closeMenu();
  });

  /* ── Scroll shadow ──────────────────────────────────── */
  const sentinel = document.getElementById("scroll-sentinel");
  if (sentinel && header) {
    new IntersectionObserver(
      ([entry]) => {
        header.classList.toggle("shadow-md",     !entry.isIntersecting);
        header.classList.toggle("shadow-ink/10", !entry.isIntersecting);
      },
      { threshold: 0 }
    ).observe(sentinel);
  }
</script>
