---
// Services — "From Leaking Faucet To Gushing Pipes"
// All three tiles: image background + bottom label bar (default) →
// dark overlay slides up on hover with checklist + description.
const commercialServices = [
  "Restaurant & kitchen plumbing",
  "High-capacity water heaters",
  "Grease trap installation",
  "Backflow prevention",
  "Commercial drain cleaning",
];

const residentialServices = [
  "Plumbing Repairs & Installation",
  "Drain & Sewer Cleaning/Replacement",
  "Water Heaters",
  "Water Line Installation",
  "Sump & Sewage Pumps",
];

const emergencyServices = [
  "Burst pipe & major leaks",
  "Sewage backups",
  "Gas line emergencies",
  "No hot water — urgent",
  "Flood damage response",
];
---

<section id="services" class="bg-surface-alt py-16 md:py-24">
  <div class="container-site">
    <!-- Heading row -->
    <div class="grid gap-6 md:grid-cols-2 md:items-end md:gap-12">
      <h2 class="text-3xl font-extrabold tracking-tight text-ink md:text-4xl">
        From Leaking Faucet To Gushing Pipes
      </h2>
      <p class="text-sm leading-relaxed text-muted md:text-base">
        While certain plumbing issues, such as a minor toilet clog, can be
        quickly addressed with do-it-yourself methods, most plumbing problems
        require the assistance of a professional — done right the first time.
      </p>
    </div>

    <!-- Cards -->
    <div class="mt-10 grid gap-5 md:grid-cols-3">

      <!-- Commercial -->
      <article class="group relative cursor-pointer overflow-hidden rounded-[3px]">
        <img
          src="/images/unsplash/service-commercial.jpg"
          alt="Plumber servicing commercial water heater equipment"
          width="480"
          height="620"
          loading="lazy"
          class="aspect-[3/4] h-full w-full object-cover transition-transform duration-700 ease-out-expo motion-reduce:transition-none group-hover:scale-105"
        />
        <!-- Bottom label bar (always visible) -->
        <div
          class="absolute inset-x-4 bottom-4 z-10 flex items-center gap-3 rounded-2xl bg-surface p-3 shadow-lg shadow-ink/10"
        >
          <span
            class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-accent text-white"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path
                d="M4 21V5a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v16M4 21h16M16 9h3a1 1 0 0 1 1 1v11M8 7h4M8 11h4M8 15h4"
                stroke="currentColor"
                stroke-width="1.7"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
            </svg>
          </span>
          <h3 class="text-sm font-bold text-ink">Commercial Services</h3>
          <svg
            class="ml-auto mr-1 shrink-0 text-ink"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            aria-hidden="true"
          >
            <path
              d="M7 17 17 7m0 0H9m8 0v8"
              stroke="currentColor"
              stroke-width="1.8"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
          </svg>
        </div>
        <!-- Slide-up overlay -->
        <div
          class="absolute inset-x-0 bottom-0 z-20 flex h-[85%] flex-col rounded-[3px] bg-ink/95 p-6 text-white translate-y-full transition-transform duration-700 ease-out-expo motion-reduce:transition-none group-hover:translate-y-0"
        >
          <span
            class="flex h-11 w-11 items-center justify-center rounded-xl bg-accent opacity-0 transition duration-300 delay-200 ease-out-expo motion-reduce:transition-none group-hover:opacity-100"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path
                d="M4 21V5a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v16M4 21h16M16 9h3a1 1 0 0 1 1 1v11M8 7h4M8 11h4M8 15h4"
                stroke="currentColor"
                stroke-width="1.7"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
            </svg>
          </span>
          <h3 class="mt-4 text-lg font-bold opacity-0 transition duration-300 delay-300 ease-out-expo motion-reduce:transition-none group-hover:opacity-100">Commercial Services</h3>
          <p class="mt-2 text-sm leading-relaxed text-white/70 opacity-0 transition duration-300 delay-400 ease-out-expo motion-reduce:transition-none group-hover:opacity-100">
            From restaurants to office buildings, we keep your business
            running with reliable commercial plumbing — minimizing downtime
            and meeting code requirements every time.
          </p>
          <ul class="mt-4 space-y-2.5 text-sm">
            {commercialServices.map((item, i) => (
              <li class="flex items-start gap-2.5 opacity-0 translate-y-2 transition-all duration-300 ease-out-expo motion-reduce:transition-none group-hover:opacity-100 group-hover:translate-y-0" style={`transition-delay: ${500 + i * 70}ms`}>
                <svg
                  class="mt-0.5 shrink-0 text-accent"
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  aria-hidden="true"
                >
                  <path
                    d="m5 12 5 5 9-10"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
      </article>

      <!-- Residential -->
      <article class="group relative cursor-pointer overflow-hidden rounded-[3px]">
        <img
          src="/images/unsplash/service-residential.jpg"
          alt="Residential plumber fixing kitchen sink pipes"
          width="480"
          height="620"
          loading="lazy"
          class="aspect-[3/4] h-full w-full object-cover transition-transform duration-700 ease-out-expo motion-reduce:transition-none group-hover:scale-105"
        />
        <!-- Bottom label bar -->
        <div
          class="absolute inset-x-4 bottom-4 z-10 flex items-center gap-3 rounded-2xl bg-surface p-3 shadow-lg shadow-ink/10"
        >
          <span
            class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-accent text-white"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path
                d="m3 11 9-8 9 8M5 9.5V21h14V9.5"
                stroke="currentColor"
                stroke-width="1.7"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
            </svg>
          </span>
          <h3 class="text-sm font-bold text-ink">Residential Services</h3>
          <svg
            class="ml-auto mr-1 shrink-0 text-ink"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            aria-hidden="true"
          >
            <path
              d="M7 17 17 7m0 0H9m8 0v8"
              stroke="currentColor"
              stroke-width="1.8"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
          </svg>
        </div>
        <!-- Slide-up overlay -->
        <div
          class="absolute inset-x-0 bottom-0 z-20 flex h-[85%] flex-col rounded-[3px] bg-ink/95 p-6 text-white translate-y-full transition-transform duration-700 ease-out-expo motion-reduce:transition-none group-hover:translate-y-0"
        >
          <span
            class="flex h-11 w-11 items-center justify-center rounded-xl bg-accent opacity-0 transition duration-300 delay-200 ease-out-expo motion-reduce:transition-none group-hover:opacity-100"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path
                d="m3 11 9-8 9 8M5 9.5V21h14V9.5"
                stroke="currentColor"
                stroke-width="1.7"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
            </svg>
          </span>
          <h3 class="mt-4 text-lg font-bold opacity-0 transition duration-300 delay-300 ease-out-expo motion-reduce:transition-none group-hover:opacity-100">Residential Services</h3>
          <p class="mt-2 text-sm leading-relaxed text-white/70 opacity-0 transition duration-300 delay-400 ease-out-expo motion-reduce:transition-none group-hover:opacity-100">
            Keep your home as comfortable as possible by making sure your
            plumbing system is working at its best. Here's just a sampling of
            the services we provide for our customers:
          </p>
          <ul class="mt-4 space-y-2.5 text-sm">
            {residentialServices.map((item, i) => (
              <li class="flex items-start gap-2.5 opacity-0 translate-y-2 transition-all duration-300 ease-out-expo motion-reduce:transition-none group-hover:opacity-100 group-hover:translate-y-0" style={`transition-delay: ${500 + i * 70}ms`}>
                <svg
                  class="mt-0.5 shrink-0 text-accent"
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  aria-hidden="true"
                >
                  <path
                    d="m5 12 5 5 9-10"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
      </article>

      <!-- Emergency -->
      <article class="group relative cursor-pointer overflow-hidden rounded-[3px]">
        <img
          src="/images/unsplash/service-emergency.jpg"
          alt="Emergency plumber fixing a burst pipe leak"
          width="480"
          height="620"
          loading="lazy"
          class="aspect-[3/4] h-full w-full object-cover transition-transform duration-700 ease-out-expo motion-reduce:transition-none group-hover:scale-105"
        />
        <!-- Bottom label bar -->
        <div
          class="absolute inset-x-4 bottom-4 z-10 flex items-center gap-3 rounded-2xl bg-surface p-3 shadow-lg shadow-ink/10"
        >
          <span
            class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-accent text-white"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path
                d="M13 2 4.5 13.5H11L9.5 22 19 10h-6.5L13 2Z"
                stroke="currentColor"
                stroke-width="1.7"
                stroke-linejoin="round"
              />
            </svg>
          </span>
          <h3 class="text-sm font-bold text-ink">Emergency Services</h3>
          <svg
            class="ml-auto mr-1 shrink-0 text-ink"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            aria-hidden="true"
          >
            <path
              d="M7 17 17 7m0 0H9m8 0v8"
              stroke="currentColor"
              stroke-width="1.8"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
          </svg>
        </div>
        <!-- Slide-up overlay -->
        <div
          class="absolute inset-x-0 bottom-0 z-20 flex h-[85%] flex-col rounded-[3px] bg-ink/95 p-6 text-white translate-y-full transition-transform duration-700 ease-out-expo motion-reduce:transition-none group-hover:translate-y-0"
        >
          <span
            class="flex h-11 w-11 items-center justify-center rounded-xl bg-accent text-white opacity-0 transition duration-300 delay-200 ease-out-expo motion-reduce:transition-none group-hover:opacity-100"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path
                d="M13 2 4.5 13.5H11L9.5 22 19 10h-6.5L13 2Z"
                stroke="currentColor"
                stroke-width="1.7"
                stroke-linejoin="round"
              />
            </svg>
          </span>
          <h3 class="mt-4 text-lg font-bold opacity-0 transition duration-300 delay-300 ease-out-expo motion-reduce:transition-none group-hover:opacity-100">Emergency Services</h3>
          <p class="mt-2 text-sm leading-relaxed text-white/70 opacity-0 transition duration-300 delay-400 ease-out-expo motion-reduce:transition-none group-hover:opacity-100">
            Plumbing emergencies don't wait — and neither do we. Day or
            night, our team is ready to respond fast and fix the problem
            before it gets worse.
          </p>
          <ul class="mt-4 space-y-2.5 text-sm">
            {emergencyServices.map((item, i) => (
              <li class="flex items-start gap-2.5 opacity-0 translate-y-2 transition-all duration-300 ease-out-expo motion-reduce:transition-none group-hover:opacity-100 group-hover:translate-y-0" style={`transition-delay: ${500 + i * 70}ms`}>
                <svg
                  class="mt-0.5 shrink-0 text-accent"
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  aria-hidden="true"
                >
                  <path
                    d="m5 12 5 5 9-10"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
      </article>
    </div>

    <!-- CTA -->
    <div class="mt-10 flex justify-center">
      <a
        href="#services"
        class="inline-flex items-center gap-2 rounded-full bg-ink px-7 py-3.5 text-sm font-semibold text-white transition hover:bg-ink-soft"
      >
        View All Services
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path
            d="M5 12h14m0 0-6-6m6 6-6 6"
            stroke="currentColor"
            stroke-width="1.8"
            stroke-linecap="round"
            stroke-linejoin="round"
          />
        </svg>
      </a>
    </div>
  </div>
</section>
