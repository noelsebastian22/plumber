---
const avatars = [
  { src: "/images/unsplash/avatar-1.jpg", alt: "Satisfied customer" },
  { src: "/images/unsplash/avatar-2.jpg", alt: "Satisfied customer" },
  { src: "/images/unsplash/avatar-3.jpg", alt: "Satisfied customer" },
];
---

<section class="bg-surface pt-12 md:pt-16" id="home">
  <div class="container-site grid gap-10 md:grid-cols-[1.15fr_1fr] md:gap-16">
    <h1 class="text-4xl leading-[1.15] tracking-tight text-ink sm:text-[2.75rem] lg:text-[3.25rem]">
      <span class="font-extrabold">A Dedicated</span>{" "}
      <span class="font-medium">Plumbing &amp; Handyman Services</span>{" "}
      <span class="font-extrabold">Company.</span>
    </h1>

    <div class="flex flex-col items-start gap-5">
      <div>
        <div class="flex items-center">
          {
            avatars.map(({ src, alt }, i) => (
              <img
                src={src}
                alt={alt}
                width="40"
                height="40"
                loading="eager"
                class:list={[
                  "h-10 w-10 rounded-full border-2 border-surface object-cover",
                  i > 0 && "-ml-3",
                ]}
              />
            ))
          }
          <span
            class="-ml-3 flex h-10 w-10 items-center justify-center rounded-full border-2 border-surface bg-accent text-white"
            aria-hidden="true"
          >
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
              <path d="M7 1v12M1 7h12" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
            </svg>
          </span>
        </div>
        <p class="mt-2 text-sm font-semibold text-ink">18k+ Satisfied Customers All Over New York</p>
      </div>

      <p class="text-sm leading-relaxed text-muted">
        With a focus on quality workmanship and customer satisfaction, we handle
        everything from plumbing repairs and installations to carpentry,
        painting, electrical fixes, and more.
      </p>

      <a
        href="#contact"
        class="rounded-full bg-accent px-6 py-3 text-sm font-semibold text-white transition-colors hover:bg-accent-dark"
      >
        Contact Us
      </a>
    </div>
  </div>
</section>

<!-- Video straddles the white→black boundary, matching the mockup split -->
<section class="mt-12 bg-gradient-to-b from-surface from-45% to-ink to-45% md:mt-16">
  <div class="container-site">
    <div class="relative aspect-[16/9] w-full overflow-hidden bg-ink-soft">
      <video
        id="hero-video"
        class="h-full w-full object-cover"
        poster="/images/hero-poster.jpg"
        preload="none"
        playsinline
        loop
        title="PLUMBER. — plumber at work"
        aria-label="Background video showing a plumber at work"
      >
        <source src="/videos/hero.mp4" type="video/mp4" />
      </video>

      <button
        id="hero-play"
        type="button"
        class="group absolute inset-0 flex items-center justify-center transition-opacity"
        aria-label="Play video"
      >
        <span
          class="flex h-16 w-16 items-center justify-center rounded-full bg-white/90 shadow-lg transition-transform group-hover:scale-105"
        >
          <svg width="18" height="20" viewBox="0 0 18 20" fill="none" aria-hidden="true">
            <path d="M2 1.8v16.4c0 .9 1 1.5 1.8 1L17 11c.8-.5.8-1.6 0-2.1L3.8.7C3 .3 2 .9 2 1.8Z" fill="#0a0a0a" />
          </svg>
        </span>
      </button>
    </div>
  </div>
</section>

<script>
  const video = document.getElementById("hero-video") as HTMLVideoElement | null;
  const play = document.getElementById("hero-play");

  play?.addEventListener("click", () => {
    if (!video || !video.paused) return;
    video.play();
    play.classList.add("opacity-0", "pointer-events-none");
  });

  video?.addEventListener("click", () => {
    if (!video.paused) {
      video.pause();
      play?.classList.remove("opacity-0", "pointer-events-none");
    }
  });
</script>
